# Product Hunt developer token
# 1. Go to https://www.producthunt.com/v2/oauth/applications
# 2. Create an application with "Add an application" (redirect URI: http://localhost:3717)
# 3. Click "Developer Token" on the app page, copy it, and paste it here
PH_TOKEN=

# OpenAI API key (used to generate the product summaries)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the summarization model (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini
